  </a>
</div>

<!-- Work Section -->
<section class="work-section animate-in">
  <h2 class="work-section__title">Work</h2>
  <div class="work-table">
    {% for job in about.work %}
    <div class="work-table__row">
      <div class="work-table__icon" style="background-color: {{ job.color }};">{{ job.icon }}</div>
      <span class="work-table__company">{{ job.company }}</span>
      <span class="work-table__role">{{ job.role }}</span>
      <span class="work-table__period">{{ job.period }}</span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Projects Section -->
<section class="section animate-in">
  <div class="section__header">
    <h2 class="section__title">Projects</h2>
  </div>
  <div class="project-list">
    {% for project in about.projects %}
    <div class="project-list__item">
      <span class="project-list__name">{% if project.isExternal %}<a href="{{ project.url }}" target="_blank" rel="noopener noreferrer">{{ project.name }} <span class="project-list__external">↗</span></a>{% else %}<a href="{{ project.url }}">{{ project.name }}</a>{% endif %}</span>
      <span class="project-list__desc">{{ project.desc }}</span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Speaking Section -->
<section class="section animate-in">
  <div class="section__header">
    <h2 class="section__title">Speaking</h2>
  </div>
  <div class="speaking-list">
    {% for talk in about.speaking %}
    <div class="speaking-list__item">
      <span class="speaking-list__title">{{ talk.title }}</span>
      <span class="speaking-list__date">{{ talk.date }}</span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Investments Section -->
<section class="section animate-in">
  <div class="section__header">
    <h2 class="section__title">Investments</h2>
  </div>
  <div class="investment-list">
    {% for inv in about.investments %}
    <div class="investment-list__item">
      <span class="investment-list__name">{{ inv.name }}</span>
      {% if inv.status %}
      <span class="investment-list__status">{{ inv.status }}</span>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>
