<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description | default(site.defaultDescription) }}">
  <title>{{ title | default(site.name) }}</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Top Navigation Bar -->
  <header class="topbar">
    <button class="topbar__menu-btn" aria-label="Open menu">
      <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="8" x2="20" y2="8"></line>
        <line x1="4" y1="16" x2="20" y2="16"></line>
      </svg>
    </button>
    {% if pageType == "about" %}
    <div class="topbar__breadcrumb">
      <a href="{{ '/' | url }}">{{ site.name }}</a>
      <span class="topbar__breadcrumb-sep">/</span>
      <span class="topbar__breadcrumb-current">About</span>
    </div>
    {% elif pageType == "writing" %}
    <div class="topbar__breadcrumb">
      <a href="{{ '/' | url }}">{{ site.name }}</a>
      <span class="topbar__breadcrumb-sep">/</span>
      <span class="topbar__breadcrumb-current">Writing</span>
    </div>
    {% elif pageType == "post" %}
    <div class="topbar__breadcrumb">
      <a href="{{ '/' | url }}">{{ site.name }}</a>
      <span class="topbar__breadcrumb-sep">/</span>
      <a href="{{ '/writing/' | url }}">Writing</a>
    </div>
    {% endif %}
  </header>

  <!-- Slide-out Navigation Drawer -->
  <nav class="nav-drawer" aria-label="Main Navigation">
    <button class="nav-drawer__close" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="nav-drawer__links">
      {% for link in site.navLinks %}
      <a href="{{ link.url | url }}" class="nav-drawer__link{% if pageType == link.pageType or (link.pageType == 'writing' and pageType == 'post') %} is-active{% endif %}">{{ link.label }}</a>
      {% endfor %}
      
      <div class="nav-drawer__section-label">Projects</div>
      {% for project in site.navProjects %}
      <a href="{{ project.url | url }}" class="nav-drawer__link nav-drawer__link--muted">{{ project.label }}</a>
      {% endfor %}
    </div>
    
    <div class="nav-drawer__social">
      <a href="{{ site.socials.twitter }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="{{ site.socials.youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      <a href="{{ site.socials.github }}" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
    </div>
  </nav>
  <div class="nav-overlay"></div>

  <!-- Page Content -->
  <main class="page-wrapper page-content">
    {{ content | safe }}
  </main>

  <script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
