<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description | default(site.defaultDescription) }}">
  <title>{{ title | default(site.name) }}</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Top Navigation Bar -->
  <header class="topbar">
    <button class="topbar__menu-btn" aria-label="Open menu">
      <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="8" x2="20" y2="8"></line>
        <line x1="4" y1="16" x2="20" y2="16"></line>
      </svg>
    </button>
    {% if pageType == "about" %}
    <div class="topbar__breadcrumb">
      <a href="{{ '/' | url }}">{{ site.name }}</a>
      <span class="topbar__breadcrumb-sep">/</span>
      <span class="topbar__breadcrumb-current">About</span>
    </div>
    {% elif pageType == "writing" %}
    <div class="topbar__breadcrumb">
      <a href="{{ '/' | url }}">{{ site.name }}</a>
      <span class="topbar__breadcrumb-sep">/</span>
      <span class="topbar__breadcrumb-current">Writing</span>
    </div>
    {% elif pageType == "post" %}
    <div class="topbar__breadcrumb">
      <a href="{{ '/' | url }}">{{ site.name }}</a>
      <span class="topbar__breadcrumb-sep">/</span>
      <a href="{{ '/writing/' | url }}">Writing</a>
    </div>
    {% endif %}
  </header>

  <!-- Slide-out Navigation Drawer -->
  <nav class="nav-drawer" aria-label="Main Navigation">
    <button class="nav-drawer__close" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="nav-drawer__links">
      {% for link in site.navLinks %}
      <a href="{{ link.url | url }}" class="nav-drawer__link{% if pageType == link.pageType or (link.pageType == 'writing' and pageType == 'post') %} is-active{% endif %}">{{ link.label }}</a>
      {% endfor %}
      
  
    </div>
    

  </nav>
  <div class="nav-overlay"></div>

  <!-- Page Content -->
  <main class="page-wrapper page-content">
    {{ content | safe }}
  </main>

  <script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
